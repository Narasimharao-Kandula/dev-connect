# ============================================
# DevConnect — Server Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================

# Database
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Auth
JWT_SECRET="your-strong-random-secret-here"
JWT_EXPIRES_IN="7d"

# Server
PORT=5000

# Client origin (used for CORS, email links, OAuth redirects)
CLIENT_URL="http://localhost:5173"

# Server public URL (used for OAuth callbacks)
SERVER_URL="http://localhost:5000"

# Email (SMTP credentials for production)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@devconnect.app"

# OAuth — Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OAuth — GitHub
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
